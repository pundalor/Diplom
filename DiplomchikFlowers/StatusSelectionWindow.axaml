<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DiplomchikFlowers.StatusSelectionWindow"
        Title="Выбор статуса"
        Width="350"
        Icon="/Images/rose.ico"
        x:CompileBindings="False"
        Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Выберите новый статус:" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

        <ListBox Grid.Row="1" x:Name="StatusListBox" SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" FontSize="13"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,15,0,0">
            <Button Content="Отмена" Width="100" Click="Cancel_Click"/>
            <Button Content="OK" Width="100" Click="Ok_Click" Classes="primary"/>
        </StackPanel>
    </Grid>
</Window>