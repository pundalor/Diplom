<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:DiplomchikFlowers"
        x:Class="DiplomchikFlowers.ProductReviewsWindow"
        Title="Отзывы о товаре"
        Width="800" Height="600"
        WindowStartupLocation="CenterOwner"
        Icon="Images/rose.ico"
        x:CompileBindings="False"
        FontFamily="Segoe UI">
    
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#FF9B6B9D"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#FFE0E0E0"/>
        <local:StarTextConverter x:Key="StarTextConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FFF9F9F9" CornerRadius="8" Padding="10" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← Назад" Click="Back_Click" Background="{StaticResource Accent}" Foreground="White" Padding="12,6" CornerRadius="8"/>
                <StackPanel Grid.Column="1" Margin="15,0,0,0">
                    <TextBlock Text="{Binding Product.Name}" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Product.Description}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Средний рейтинг: "/>
                        <TextBlock Text="{Binding AverageRating}" Foreground="Orange"/>
                        <TextBlock Text=" / 5"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,15" IsVisible="{Binding CanReview}">
            <StackPanel>
                <TextBlock Text="Оставить отзыв" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <TextBlock Text="Оценка: "/>
                    <ComboBox x:Name="RatingComboBox" Width="80" SelectedIndex="0">
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="1"/>
                    </ComboBox>
                    <TextBlock Text="{Binding SelectedIndex, ElementName=RatingComboBox, Converter={StaticResource StarTextConverter}, ConverterParameter=5}" Margin="5,0,0,0"/>
                </StackPanel>
                <TextBox x:Name="CommentBox" Watermark="Ваш комментарий..." AcceptsReturn="True" Height="80"/>
                <Button Content="Отправить отзыв" Click="SendReview_Click" HorizontalAlignment="Right" Margin="0,10,0,0" Background="{StaticResource Accent}" Foreground="White"/>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="2">
            <ItemsControl x:Name="ReviewsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FFF9F9F9" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding CustomerName}" FontWeight="Bold"/>
                                        <TextBlock Text=" • " Margin="5,0"/>
                                        <TextBlock Text="{Binding Rating}"/>
                                        <TextBlock Text="{Binding Rating, Converter={StaticResource StarTextConverter}}" Margin="2,0"/>
                                        <TextBlock Text=" • " Margin="5,0"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" Foreground="Gray"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding DisplayComment}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Top">
                                    <Button Content="✏️" Width="30" Click="EditReview_Click" Tag="{Binding}" IsVisible="{Binding IsOwner}"/>
                                    <Button Content="🗑️" Width="30" Background="#FFE74C3C" Click="DeleteReview_Click" Tag="{Binding}" IsVisible="{Binding CanDelete}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>