<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DiplomchikFlowers.UserEditWindow"
        Title="Пользователь"
        Width="450"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Icon="/Images/rose.ico"
        FontFamily="Segoe UI, sans-serif"
        MinWidth="400">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF9B6B9D"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFE74C3C"/>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock Text="Добавление / Редактирование пользователя" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,15"/>

        <TextBlock Text="Полное имя *" FontSize="12" Margin="0,5,0,0"/>
        <TextBox x:Name="FullNameBox" Watermark="Иванов Иван Иванович" Margin="0,5"/>

        <TextBlock Text="Email *" FontSize="12" Margin="0,10,0,0"/>
        <TextBox x:Name="EmailBox" Watermark="example@mail.com" Margin="0,5"/>

        <TextBlock Text="Телефон *" FontSize="12" Margin="0,10,0,0"/>
        <TextBox x:Name="PhoneBox" Watermark="+7 (123) 456-78-90" Margin="0,5"/>

        <TextBlock Text="Город" FontSize="12" Margin="0,10,0,0"/>
        <TextBox x:Name="CityBox" Watermark="Город" Margin="0,5"/>

        <TextBlock Text="Адрес" FontSize="12" Margin="0,10,0,0"/>
        <TextBox x:Name="AddressBox" Watermark="Улица, дом, квартира" Margin="0,5"/>

        <TextBlock Text="Роль *" FontSize="12" Margin="0,10,0,0"/>
        <ComboBox x:Name="RoleCombo" Margin="0,5">
            <ComboBoxItem Content="Пользователь" Tag="3"/>
            <ComboBoxItem Content="Менеджер" Tag="2"/>
            <ComboBoxItem Content="Администратор" Tag="1"/>
        </ComboBox>

        <TextBlock x:Name="PasswordBlock" Text="Пароль *" FontSize="12" Margin="0,10,0,0"/>
        <TextBox x:Name="PasswordBox" Watermark="Введите пароль (мин. 6 символов)" Margin="0,5"/>

        <TextBlock x:Name="ErrorTextBlock" Foreground="{StaticResource ErrorBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0" IsVisible="False"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0" Spacing="15">
            <Button Content="Сохранить" Click="Save_Click" Padding="20,8"/>
            <Button Content="Отмена" Click="Cancel_Click" Background="LightGray" Foreground="Black" Padding="20,8"/>
        </StackPanel>
    </StackPanel>
</Window>