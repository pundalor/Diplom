<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DiplomchikFlowers.ProductEditWindow"
        Title="Редактирование товара"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        Icon="/Images/rose.ico"
        FontFamily="Segoe UI, sans-serif"
        MinWidth="450">
    
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF9B6B9D"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFE74C3C"/>
    </Window.Resources>

    <StackPanel Margin="20" Width="450">
        <TextBlock Text="Добавление/Редактирование товара" FontSize="16" FontWeight="Bold" 
                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,15"/>

        <TextBlock Text="Название *" FontSize="12" Margin="0,5,0,0"/>
        <TextBox x:Name="NameBox" Watermark="Введите название" Margin="0,5"/>

        <TextBlock Text="Описание" FontSize="12" Margin="0,10,0,0"/>
        <TextBox x:Name="DescriptionBox" Watermark="Описание товара" TextWrapping="Wrap" 
                 Height="80" Margin="0,5"/>

        <TextBlock Text="Цена *" FontSize="12" Margin="0,10,0,0"/>
        <TextBox x:Name="PriceBox" Watermark="Цена" Margin="0,5" />

        <TextBlock Text="Количество на складе *" FontSize="12" Margin="0,10,0,0"/>
        <TextBox x:Name="StockBox" Watermark="Количество" Margin="0,5" />

        <TextBlock Text="Категория *" FontSize="12" Margin="0,10,0,0"/>
        <ComboBox x:Name="CategoryCombo" PlaceholderText="Выберите категорию" Margin="0,5"/>
        <Border BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,10,0,0">
            <StackPanel>
                <TextBlock Text="Скидка" FontWeight="Bold" Margin="0,0,0,8" Foreground="{StaticResource AccentBrush}"/>
                
                <TextBlock Text="Процент скидки" FontSize="12" Margin="0,5,0,0"/>
                <TextBox x:Name="DiscountPercentBox" Margin="0,5"/>
                
                <TextBlock Text="Дата начала скидки" FontSize="12" Margin="0,10,0,0"/>
                <DatePicker x:Name="DiscountStartDatePicker" Margin="0,5" />
                
                <TextBlock Text="Дата окончания скидки" FontSize="12" Margin="0,10,0,0"/>
                <DatePicker x:Name="DiscountEndDatePicker" Margin="0,5" />
            </StackPanel>
        </Border>

        <TextBlock Text="Изображение" FontSize="12" Margin="0,10,0,0"/>
        <Grid ColumnDefinitions="*, Auto" Margin="0,5">
            <TextBox x:Name="ImagePathBox" IsReadOnly="True" Watermark="Файл не выбран" 
                     VerticalAlignment="Center" Grid.Column="0"/>
            <Button Content="Выбрать..." Grid.Column="1" Margin="10,0,0,0" 
                    Click="SelectImage_Click" Width="80"/>
        </Grid>
        <Border Background="#F0F0F0" CornerRadius="8" Height="120" Margin="0,5" 
                BorderBrush="#CCCCCC" BorderThickness="1">
            <Image x:Name="ImagePreview" Stretch="Uniform" 
                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <TextBlock x:Name="ErrorTextBlock" Foreground="{StaticResource ErrorBrush}" 
                   FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0" IsVisible="False"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0" Spacing="15">
            <Button Content="Сохранить" Click="Save_Click" Padding="20,8"/>
            <Button Content="Отмена" Click="Cancel_Click" Background="LightGray" Foreground="Black" Padding="20,8"/>
        </StackPanel>
    </StackPanel>
</Window>