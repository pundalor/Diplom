<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DiplomchikFlowers.ForgotPasswordWindow"
        Title="Сброс пароля"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        FontFamily="Segoe UI, sans-serif"
        Icon="Images/rose.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF9B6B9D"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="BorderBrush" Value="#FFD0B4D4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Styles>

    <StackPanel Margin="30" HorizontalAlignment="Center" Width="280">
        <TextBlock Text="Сброс пароля" 
                   FontSize="16" FontWeight="Bold" 
                   Foreground="{StaticResource AccentBrush}" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBox x:Name="EmailBox" Watermark="Введите ваш email"/>
        <TextBox x:Name="NewPasswordBox" Watermark="Новый пароль" PasswordChar="*"/>
        <TextBox x:Name="ConfirmPasswordBox" Watermark="Подтвердите пароль" PasswordChar="*"/>

        <Button Content="Сбросить пароль" Click="ResetPassword_Click" Margin="0,20,0,5"/>
        <Button Content="Отмена" Click="Cancel_Click" Background="LightGray" Foreground="Black"/>
    </StackPanel>
</Window>